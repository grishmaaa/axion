  p[0] = 1.5; p[1] = -2.5; p[2] = 0.0;

  auto out = aten::cpu_kernel_unary(t, [](double x) { return x * 2.0; });

  double* o = out.data_ptr<double>();
  EXPECT_DOUBLE_EQ(o[0], 3.0);
  EXPECT_DOUBLE_EQ(o[1], -5.0);
  EXPECT_DOUBLE_EQ(o[2], 0.0);
