  auto dp = alloc->allocate(100);
  auto addr = reinterpret_cast<uintptr_t>(dp.get());
  EXPECT_EQ(addr % kCPUAlignment, 0u)
      << "Pointer " << dp.get() << " is not 64-byte aligned";
}

